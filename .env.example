# ─── Garda Bencana — React Native App Environment ─────────────────────────
# Salin/rename file ini jadi .env lalu isi nilainya

# Untuk development lokal (server Express masih jalan di localhost atau Replit):
# EXPO_PUBLIC_DOMAIN=localhost:5000

# Untuk production (setelah backend di-deploy ke Vercel):
# EXPO_PUBLIC_API_URL=https://garda-bencana-api.vercel.app
# (Ganti dengan URL Vercel yang sebenarnya setelah deploy)
